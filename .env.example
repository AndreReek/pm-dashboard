# =============================================================================
# Fieldline — Environment Variables Reference
# =============================================================================
# This file is committed to the repo as documentation only.
# NEVER put real values here.
#
# Where to set real values:
#   - Vercel dashboard → Project → Settings → Environment Variables
#   - Supabase dashboard → Edge Functions → Secrets (for server-side secrets)
#
# The frontend (HTML/JS) reads Supabase credentials that are hardcoded directly
# in the HTML files because they are publishable keys (anon key). This is safe
# and intentional — the anon key is not a secret.
# See: https://supabase.com/docs/guides/api/api-keys
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE (Frontend — public, safe to commit in HTML)
# -----------------------------------------------------------------------------
# These are already hardcoded in dashboard.html, login.html, join.html.
# They are listed here for documentation purposes only.

SUPABASE_URL=https://your-project-id.supabase.co
# The anon/publishable key — NOT a secret, safe in client-side code.
# Access is controlled by Row Level Security (RLS) policies in PostgreSQL.
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# STRIPE (Server-side only — Supabase Edge Functions secrets)
# -----------------------------------------------------------------------------
# These NEVER go in the frontend. They live exclusively in:
#   Supabase dashboard → Edge Functions → Manage secrets
#
# Set them via Supabase CLI:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Secret API Key (sk_live_... for production, sk_test_... for staging)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe Webhook Signing Secret — found in Stripe dashboard → Webhooks → endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Stripe Price IDs (these are public identifiers, safe to commit)
STRIPE_PRICE_PRO=price_1T7f8CFAY0SgGV6JuTDa4ZZl
STRIPE_PRICE_STUDIO=price_1T7f8RFAY0SgGV6JzfQSGvaP


# -----------------------------------------------------------------------------
# VERCEL (CI/CD — GitHub Actions secrets)
# -----------------------------------------------------------------------------
# Used by .github/workflows/deploy.yml via GitHub repository secrets.
# Set in: GitHub repo → Settings → Secrets and variables → Actions
#
# How to get these values:
#   VERCEL_TOKEN:      Vercel dashboard → Account Settings → Tokens → Create
#   VERCEL_ORG_ID:     vercel.json or `vercel link` output (team ID or personal account ID)
#   VERCEL_PROJECT_ID: .vercel/project.json after running `vercel link` locally

VERCEL_TOKEN=your_vercel_personal_access_token
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxx
